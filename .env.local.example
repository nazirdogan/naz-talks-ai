# Beehiiv API credentials
# Get these from: app.beehiiv.com → Settings → API Keys
BEEHIIV_API_KEY=your_api_key_here

# Get this from: app.beehiiv.com → Settings → Publication → Publication ID
# Looks like: pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
